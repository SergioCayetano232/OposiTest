# Plantilla del .env. Copia este fichero como ".env" y rellena los valores.
# El .env de verdad no se sube a GitHub.

PORT=3000

# Cadena de conexion de MongoDB Atlas (empieza por mongodb+srv://)
URL_MONGODB=

# Claves de Mailjet, las da su panel en "API Key Management"
MAILJET_PUBLIC_APIKEY=
MAILJET_SECRET_APIKEY=

# Correo verificado en Mailjet desde el que salen los emails
MAILJET_EMAIL_REMITENTE=
MAILJET_NOMBRE_REMITENTE=OposiTest

# Texto largo y secreto con el que se firman los tokens JWT
FIRMA_JWT_SERVER=

# Direccion del Angular, para darle permiso de llamar a esta API (CORS)
URL_FRONTEND=http://localhost:4200
